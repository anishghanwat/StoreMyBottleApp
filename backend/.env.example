# Database Configuration
# SECURITY: Use a dedicated database user with limited privileges (NOT root!)
# Create user: CREATE USER 'storemybottle_user'@'localhost' IDENTIFIED BY 'strong_password';
# Grant privileges: GRANT SELECT, INSERT, UPDATE, DELETE ON storemybottle.* TO 'storemybottle_user'@'localhost';
# For production, use SSL: ?ssl_mode=REQUIRED
DATABASE_URL=mysql+pymysql://storemybottle_user:STRONG_PASSWORD_HERE@localhost:3306/storemybottle

# JWT Configuration
# Generate a strong secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER use the example value below - generate your own!
# Use different secrets for dev/staging/prod environments
JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_MINIMUM_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Resend (Email Service)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@yourdomain.com

# Cloudinary (Profile Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (for CORS)
FRONTEND_URL=https://storemybottle.in

# Environment
ENVIRONMENT=production

# CORS Configuration (Optional - production origins are auto-included)
# Comma-separated list of additional allowed origins beyond the defaults
# Defaults already include: storemybottle.in, www, admin, bartender subdomains
# CORS_ORIGINS=https://extra.yourdomain.com

# Web Push (VAPID) — generate with: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()));"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@storemybottle.in